{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "conditional object validators",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "seats": {
      "type": "integer"
    },
    "contact": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "if": {
    "required": ["kind"],
    "properties": {
      "kind": {
        "const": "business"
      }
    }
  },
  "then": {
    "required": ["seats", "contact"],
    "properties": {
      "seats": {
        "type": "integer",
        "minimum": 2,
        "maximum": 8
      },
      "contact": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "else": {
    "required": ["reason"],
    "properties": {
      "reason": {
        "enum": ["personal", "trial"]
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "maxItems": 2
      }
    }
  },
  "additionalProperties": false
}
