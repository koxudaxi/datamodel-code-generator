{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "object context alias validators",
  "type": "object",
  "properties": {
    "credit-card": {
      "type": "number"
    },
    "billing-address": {
      "type": "string"
    },
    "x-count": {
      "type": "integer"
    },
    "mode-type": {
      "type": "string"
    },
    "service-code": {
      "type": "string"
    }
  },
  "dependentSchemas": {
    "credit-card": {
      "required": ["billing-address"],
      "propertyNames": {
        "pattern": "^(credit-card|billing-address|x-count)$"
      },
      "properties": {
        "credit-card": true,
        "billing-address": {
          "type": "string",
          "minLength": 3
        }
      },
      "patternProperties": {
        "^x-": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "if": {
    "required": ["mode-type"],
    "properties": {
      "mode-type": {
        "const": "strict"
      }
    }
  },
  "then": {
    "required": ["service-code"],
    "properties": {
      "mode-type": true,
      "service-code": {
        "type": "string",
        "pattern": "^S-"
      },
      "x-count": true
    },
    "additionalProperties": false
  },
  "not": {
    "required": ["bad-code"],
    "properties": {
      "bad-code": {
        "const": true
      }
    }
  },
  "additionalProperties": true
}
