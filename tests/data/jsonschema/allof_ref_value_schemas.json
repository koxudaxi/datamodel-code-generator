{
  "title": "AllofRefValueSchemas",
  "$defs": {
    "Tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "PrefixedMap": {
      "type": "object",
      "propertyNames": {
        "pattern": "^x_"
      },
      "additionalProperties": {
        "type": "integer"
      }
    },
    "ShortCode": {
      "allOf": [
        {
          "type": "string"
        },
        {
          "minLength": 2
        }
      ]
    }
  },
  "type": "object",
  "properties": {
    "tags": {
      "allOf": [
        {
          "$ref": "#/$defs/Tags"
        },
        {
          "minItems": 1
        }
      ]
    },
    "limitedTags": {
      "allOf": [
        {
          "$ref": "#/$defs/Tags"
        },
        {
          "maxItems": 2
        }
      ]
    },
    "inlineCode": {
      "allOf": [
        {
          "$ref": "#/$defs/ShortCode",
          "maxLength": 8
        }
      ]
    },
    "metadata": {
      "allOf": [
        {
          "$ref": "#/$defs/PrefixedMap"
        },
        {
          "minProperties": 1
        }
      ]
    },
    "limitedMetadata": {
      "allOf": [
        {
          "$ref": "#/$defs/PrefixedMap"
        },
        {
          "maxProperties": 2
        }
      ]
    },
    "strictMetadata": {
      "allOf": [
        {
          "$ref": "#/$defs/PrefixedMap"
        },
        {
          "propertyNames": {
            "minLength": 4
          },
          "additionalProperties": {
            "minimum": 1
          },
          "maxProperties": 2
        }
      ]
    },
    "code": {
      "allOf": [
        {
          "$ref": "#/$defs/ShortCode"
        },
        {
          "maxLength": 8
        }
      ]
    }
  }
}
