{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DependentSchemaConditionalRequiredIntersection",
  "type": "object",
  "properties": {
    "a": {
      "type": "string"
    },
    "b": {
      "type": "string"
    },
    "c": {
      "type": "string"
    }
  },
  "required": ["a", "b"],
  "dependentSchemas": {
    "a": {
      "if": {
        "required": ["b"]
      },
      "then": {
        "required": ["c"]
      }
    }
  }
}
