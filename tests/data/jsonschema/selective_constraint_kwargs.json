{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SelectiveConstraintKwargs",
  "type": "object",
  "properties": {
    "count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9,
      "multipleOf": 2
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 8,
      "pattern": "^[A-Z]+$"
    },
    "payload": {
      "type": "string",
      "format": "binary",
      "minLength": 4,
      "maxLength": 12,
      "pattern": "^[A-Z0-9]+$"
    },
    "enabled": {
      "type": "boolean"
    }
  },
  "required": ["count", "name", "payload", "enabled"]
}
