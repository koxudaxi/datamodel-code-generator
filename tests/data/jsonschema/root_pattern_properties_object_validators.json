{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "root pattern properties object validators",
  "type": "object",
  "patternProperties": {
    "^item-": {
      "type": "object",
      "required": [
        "id",
        "enabled"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "^blocked": false
  },
  "additionalProperties": false
}
