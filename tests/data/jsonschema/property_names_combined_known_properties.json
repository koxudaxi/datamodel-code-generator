{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PropertyNamesCombinedKnownProperties",
  "type": "object",
  "properties": {
    "alpha": {
      "type": "string"
    },
    "beta": {
      "type": "integer",
      "minimum": 1
    },
    "gamma": {
      "type": "boolean"
    }
  },
  "required": ["alpha"],
  "propertyNames": {
    "anyOf": [
      {
        "const": "alpha"
      },
      {
        "allOf": [
          {
            "enum": ["beta", "gamma"]
          },
          {
            "minLength": 4,
            "pattern": "^b"
          }
        ]
      }
    ]
  },
  "additionalProperties": false
}
