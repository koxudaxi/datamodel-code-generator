{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CatalogDocument",
  "description": "Catalog payload accepted by the public API.",
  "type": "object",
  "properties": {
    "primaryAddress": {
      "$ref": "#/definitions/Address"
    },
    "externalAddress": {
      "$ref": "practical_preset_external.json#/definitions/Address"
    },
    "billingAddress": {
      "title": "Address",
      "description": "Inline billing address that should not take the primary Address name.",
      "type": "object",
      "properties": {
        "streetName": {
          "description": "Street name shown on invoices.",
          "type": "string",
          "examples": [
            "Main Street"
          ]
        },
        "postalCode": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "createdBy": {
      "title": "AuditActor",
      "description": "Actor associated with the catalog entry.",
      "type": "object",
      "properties": {
        "displayName": {
          "description": "Human readable actor name.",
          "type": "string",
          "examples": [
            "Jane Admin"
          ]
        },
        "identifier": {
          "type": "string"
        }
      }
    },
    "updatedBy": {
      "title": "AuditActor",
      "description": "Actor associated with the catalog entry.",
      "type": "object",
      "properties": {
        "displayName": {
          "description": "Human readable actor name.",
          "type": "string",
          "examples": [
            "Jane Admin"
          ]
        },
        "identifier": {
          "type": "string"
        }
      }
    },
    "status": {
      "description": "Single allowed catalog status.",
      "type": "string",
      "enum": [
        "active"
      ]
    }
  },
  "definitions": {
    "Address": {
      "type": "object",
      "description": "Primary reusable address definition.",
      "properties": {
        "streetName": {
          "description": "Street name stored in the canonical address.",
          "type": "string"
        },
        "countryCode": {
          "type": "string"
        }
      }
    }
  }
}
