{
  "title": "runtime composed schema validators",
  "type": "object",
  "properties": {
    "gate": {
      "type": "boolean"
    },
    "values": {
      "type": "array"
    },
    "name": {
      "type": "string"
    }
  },
  "dependentSchemas": {
    "gate": {
      "required": [
        "values"
      ],
      "properties": {
        "values": {
          "type": "array",
          "items": {
            "allOf": [
              {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 2
                  },
                  {
                    "type": "string",
                    "pattern": "^v-"
                  }
                ]
              },
              {
                "not": {
                  "const": "v-bad"
                }
              }
            ]
          }
        }
      }
    }
  },
  "patternProperties": {
    "^x-": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^x-"
        }
      ]
    }
  },
  "additionalProperties": {
    "anyOf": [
      {
        "type": "string",
        "pattern": "^extra-"
      },
      {
        "type": "integer",
        "minimum": 100
      }
    ]
  }
}
