{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DependentSchemaIntersection",
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "enum": ["card", "cash"]
    },
    "billing_address": {
      "type": "string",
      "minLength": 3
    },
    "limit": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["method"],
  "dependentSchemas": {
    "method": {
      "properties": {
        "method": {
          "const": "card"
        },
        "billing_address": {
          "maxLength": 8
        },
        "limit": {
          "maximum": 5
        }
      },
      "required": ["billing_address", "limit"],
      "additionalProperties": false
    }
  }
}
