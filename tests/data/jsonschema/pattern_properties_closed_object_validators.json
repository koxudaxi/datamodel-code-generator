{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pattern properties closed object validators",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    }
  },
  "required": ["id"],
  "patternProperties": {
    "^s_": {
      "type": "string",
      "minLength": 2
    },
    "^i_": {
      "type": "integer",
      "minimum": 1
    },
    "^blocked_": false
  },
  "additionalProperties": false
}
