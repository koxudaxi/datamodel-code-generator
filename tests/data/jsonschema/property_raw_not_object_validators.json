{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "property raw not object validators",
  "type": "object",
  "required": [
    "payload"
  ],
  "properties": {
    "payload": {
      "type": "object",
      "properties": {
        "a": {
          "type": "integer"
        }
      },
      "not": {
        "required": [
          "b"
        ]
      }
    }
  }
}
