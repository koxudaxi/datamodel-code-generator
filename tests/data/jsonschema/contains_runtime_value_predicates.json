{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "contains runtime value predicates",
  "type": "object",
  "required": ["numbers", "names", "objects"],
  "properties": {
    "numbers": {
      "type": "array",
      "items": {},
      "contains": {
        "type": "integer",
        "minimum": 2,
        "maximum": 4,
        "multipleOf": 2
      },
      "minContains": 1,
      "maxContains": 1
    },
    "names": {
      "type": "array",
      "items": {},
      "contains": {
        "type": "string",
        "pattern": "^A",
        "minLength": 2
      },
      "minContains": 1,
      "maxContains": 1
    },
    "objects": {
      "type": "array",
      "items": {},
      "contains": {
        "type": "object",
        "required": ["kind", "values"],
        "minProperties": 2,
        "maxProperties": 2,
        "propertyNames": {
          "pattern": "^(kind|values)$"
        },
        "properties": {
          "kind": {
            "const": "ok"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1
            },
            "minItems": 2,
            "maxItems": 2
          },
          "blocked": false
        }
      },
      "minContains": 1,
      "maxContains": 1
    }
  }
}
