{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Container",
    "definitions": {
        "Base": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer"
                }
            },
            "required": ["id"]
        }
    },
    "allOf": [
        {"$ref": "#/definitions/Base"},
        {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "default": "unnamed"
                },
                "tag": {
                    "type": "string"
                }
            },
            "required": ["name", "tag"]
        }
    ]
}
