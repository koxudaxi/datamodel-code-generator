{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AllOfExtraItems",
  "type": "object",
  "$defs": {
    "BaseExtra": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        }
      }
    }
  },
  "properties": {
    "name": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "allOf": [
      {
        "$ref": "#/$defs/BaseExtra"
      },
      {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          }
        }
      }
    ]
  }
}
