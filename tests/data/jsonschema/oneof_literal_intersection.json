{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OneOfLiteralIntersection",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "oneOf": [
        {
          "enum": ["draft", "ready"]
        },
        {
          "enum": ["ready", "archived"]
        },
        {
          "const": "blocked"
        }
      ]
    },
    "level": {
      "type": "integer",
      "oneOf": [
        {
          "enum": [1, 2],
          "minimum": 1
        },
        {
          "enum": [2, 3]
        },
        {
          "const": 4
        }
      ]
    }
  },
  "required": ["status", "level"]
}
