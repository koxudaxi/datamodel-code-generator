{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PropertyNamesRefPatternPropertiesIntersection",
  "$defs": {
    "KeyName": {
      "type": "string",
      "minLength": 4
    }
  },
  "type": "object",
  "properties": {
    "scores": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/KeyName"
      },
      "patternProperties": {
        "^x_": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["scores"]
}
