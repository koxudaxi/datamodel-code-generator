{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StructuredImports",
  "type": "object",
  "properties": {
    "nullable_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "required_value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "required_value"
  ]
}
