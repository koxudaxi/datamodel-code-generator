{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$defs": {
    "Status": {
      "type": "string",
      "enum": ["active", "inactive"]
    }
  },
  "type": "object",
  "properties": {
    "status": {
      "$ref": "#/$defs/Status",
      "const": "active"
    },
    "nullable_status": {
      "$ref": "#/$defs/Status",
      "nullable": true,
      "const": "active"
    }
  },
  "required": ["status"]
}
