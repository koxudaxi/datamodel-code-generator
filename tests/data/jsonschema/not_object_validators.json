{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "not object validators",
  "type": "object",
  "properties": {
    "status": {
      "type": "string"
    },
    "archived": {
      "type": "boolean"
    },
    "score": {
      "type": "integer"
    }
  },
  "not": {
    "type": "object",
    "required": ["status", "archived"],
    "properties": {
      "status": {
        "const": "closed"
      },
      "archived": {
        "const": false
      }
    }
  },
  "additionalProperties": false
}
