{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Response",
  "type": "object",
  "allOf": [
    {
      "$ref": "base.json"
    }
  ],
  "oneOf": [
    {
      "title": "Success",
      "properties": {
        "status": {
          "type": "string",
          "const": "success"
        },
        "data": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "data"
      ]
    },
    {
      "title": "Error",
      "properties": {
        "status": {
          "type": "string",
          "const": "error"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "message"
      ]
    }
  ],
  "properties": {}
}
