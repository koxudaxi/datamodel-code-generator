{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PropertyNamesRefWithConstraints",
  "$defs": {
    "KeyName": {
      "type": "string",
      "minLength": 4
    }
  },
  "type": "object",
  "propertyNames": {
    "$ref": "#/$defs/KeyName",
    "pattern": "^x_"
  },
  "additionalProperties": {
    "type": "integer"
  }
}
