{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "object context schema validators",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "flag": {
      "type": "boolean"
    },
    "loose": {
      "type": "boolean"
    }
  },
  "dependentSchemas": {
    "flag": {
      "minProperties": 2,
      "propertyNames": {
        "pattern": "^(mode|code|flag|x-[a-z]+)$"
      },
      "properties": {
        "mode": true,
        "code": true,
        "flag": true
      },
      "patternProperties": {
        "^x-": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "if": {
    "required": ["mode"],
    "properties": {
      "mode": {
        "const": "strict"
      }
    }
  },
  "then": {
    "required": ["code"],
    "properties": {
      "mode": true,
      "code": {
        "type": "string",
        "pattern": "^S-"
      }
    },
    "patternProperties": {
      "^x-": {
        "type": "integer",
        "minimum": 1
      }
    },
    "additionalProperties": false
  },
  "else": {
    "properties": {
      "mode": true,
      "flag": true,
      "loose": true,
      "code": {
        "type": "string",
        "pattern": "^L-"
      }
    },
    "additionalProperties": {
      "type": "integer",
      "minimum": 0
    }
  },
  "not": {
    "minProperties": 1,
    "propertyNames": {
      "pattern": "^bad$"
    }
  },
  "additionalProperties": true
}
