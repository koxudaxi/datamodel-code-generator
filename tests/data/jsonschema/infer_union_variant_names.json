{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebhookEnvelope",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {"const": "message.created"},
            "id": {"type": "string"}
          }
        },
        {
          "type": "object",
          "required": ["type", "reason"],
          "properties": {
            "type": {"const": "message.failed"},
            "reason": {"type": "string"}
          }
        }
      ]
    }
  }
}
