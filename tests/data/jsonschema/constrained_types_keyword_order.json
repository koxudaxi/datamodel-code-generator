{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "count": {"type": "integer", "exclusiveMinimum": 0, "maximum": 200},
    "ratio": {"type": "number", "minimum": 0.5, "exclusiveMaximum": 1.5, "multipleOf": 0.1},
    "name": {"type": "string", "pattern": "^[a-z]+$", "minLength": 2, "maxLength": 10},
    "tags": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string"}}
  },
  "required": ["count", "name"]
}
