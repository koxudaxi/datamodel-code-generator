{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Additional properties type specific constraints",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ],
  "additionalProperties": {
    "type": [
      "string",
      "number",
      "array",
      "boolean",
      "object"
    ],
    "allOf": [
      {
        "maxLength": 3
      },
      {
        "pattern": "^[A-Z]+$"
      },
      {
        "minimum": 10
      },
      {
        "multipleOf": 2
      },
      {
        "maxItems": 2
      }
    ]
  }
}
