{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "object context nested alias model value validators",
  "type": "object",
  "properties": {
    "trigger": {
      "type": "boolean"
    },
    "profile-data": {
      "type": "object",
      "required": [
        "service-code",
        "quota-limit"
      ],
      "properties": {
        "service-code": {
          "type": "string"
        },
        "quota-limit": {
          "type": "integer"
        },
        "optional-flag": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "dependentSchemas": {
    "trigger": {
      "required": [
        "profile-data"
      ],
      "properties": {
        "profile-data": {
          "type": "object",
          "required": [
            "service-code",
            "quota-limit"
          ],
          "properties": {
            "service-code": {
              "type": "string",
              "pattern": "^S-"
            },
            "quota-limit": {
              "type": "integer",
              "minimum": 2
            }
          }
        }
      }
    }
  },
  "if": {
    "required": [
      "profile-data"
    ],
    "properties": {
      "profile-data": {
        "type": "object",
        "required": [
          "optional-flag"
        ],
        "properties": {
          "optional-flag": {
            "const": true
          }
        }
      }
    }
  },
  "then": {
    "properties": {
      "profile-data": {
        "type": "object",
        "properties": {
          "quota-limit": {
            "type": "integer",
            "maximum": 5
          }
        }
      }
    }
  },
  "additionalProperties": false
}
