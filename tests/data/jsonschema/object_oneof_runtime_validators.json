{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "object oneof runtime validators",
  "type": "object",
  "properties": {
    "anything_except_string": {
      "oneOf": [
        true,
        {
          "type": "string"
        }
      ]
    },
    "number_not_integer": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "number"
        }
      ]
    }
  },
  "required": [
    "anything_except_string",
    "number_not_integer"
  ]
}
