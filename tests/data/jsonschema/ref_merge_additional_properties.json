{
  "$schema": "https://json-schema.org/draft/2020-12/schema#",
  "$defs": {
    "ConstrainedString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "DictModel": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ConstrainedString",
        "const": "fixed"
      }
    }
  },
  "type": "object",
  "properties": {
    "data": {
      "$ref": "#/$defs/DictModel"
    }
  }
}
