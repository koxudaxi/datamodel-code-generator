{
  "openapi": "3.1.0",
  "info": {
    "title": "sort_data_models infinite loop reproducer",
    "version": "1.0",
    "description": "Discriminated oneOf (X) with variants that allOf-reference X causes circular inheritance among generated models. sort_data_models then never converges (while-loop oscillation). See parser/base.py sort_data_models."
  },
  "paths": {},
  "components": {
    "schemas": {
      "X": {
        "type": "object",
        "discriminator": {
          "propertyName": "kind"
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/A"
          },
          {
            "$ref": "#/components/schemas/B"
          }
        ]
      },
      "A": {
        "allOf": [
          {
            "$ref": "#/components/schemas/X"
          },
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "const": "a"
              }
            }
          }
        ]
      },
      "B": {
        "allOf": [
          {
            "$ref": "#/components/schemas/X"
          },
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "const": "b"
              }
            }
          }
        ]
      }
    }
  }
}
