{%- if schema_runtime_validation %}
{%- set schema_validator_state = namespace(has_prior=description or config or class_body_lines) %}
{%- for rule in schema_runtime_validation.pattern_properties %}
{%- if schema_validator_state.has_prior or not loop.first %}

{%- endif %}
    @model_validator(mode='before')
    @classmethod
    def _validate_schema_pattern_properties(cls, data: Any) -> Any:
        if not isinstance(data, dict):
            return data
        values = dict(data)
        declared_properties = {{ rule.declared_properties|repr }}
        rejected_patterns = {{ rule.rejected_patterns|repr }}
        pattern_properties = (
{%- for pattern, data_type in rule.pattern_properties %}
            ({{ pattern|repr }}, {{ data_type.type_hint }}),
{%- endfor %}
        )
        additional_property_type = {% if rule.additional_property_type %}{{ rule.additional_property_type.type_hint }}{% else %}None{% endif %}
        for key, value in data.items():
            if key in declared_properties:
                continue
            if any(re.search(pattern, key) for pattern in rejected_patterns):
                raise ValueError(
                    f'Property {key!r} is not allowed by patternProperties'
                )
            matched = False
            for pattern, value_type in pattern_properties:
                if not re.search(pattern, key):
                    continue
                matched = True
                value = TypeAdapter(value_type).validate_python(value)
            if matched:
                values[key] = value
                continue
            if additional_property_type is not None:
                values[key] = TypeAdapter(additional_property_type).validate_python(
                    value
                )
                continue
{%- if not rule.allow_unmatched %}
            raise ValueError(f'Unexpected property {key!r}')
{%- endif %}
        return values
{%- set schema_validator_state.has_prior = true %}
{%- endfor %}
{%- for rule in schema_runtime_validation.required_groups %}
{%- if schema_validator_state.has_prior %}

{%- endif %}
    @model_validator(mode='before')
    @classmethod
    def _validate_schema_{{ 'one_of' if rule.keyword == 'oneOf' else 'any_of' }}_required(cls, data: Any) -> Any:
        if not isinstance(data, dict):
            return data
        required_groups = {{ rule.groups|repr }}
        matches = sum(
            all(any(name in data for name in names) for names in group)
            for group in required_groups
        )
{%- if rule.keyword == 'oneOf' %}
        if matches != 1:
            raise ValueError(
                'Expected exactly one required property group to be present'
            )
{%- else %}
        if matches == 0:
            raise ValueError(
                'Expected at least one required property group to be present'
            )
{%- endif %}
        return data
{%- set schema_validator_state.has_prior = true %}
{%- endfor %}
{%- for rule in schema_runtime_validation.conditional_required %}
{%- if schema_validator_state.has_prior %}

{%- endif %}
    @model_validator(mode='before')
    @classmethod
    def _validate_schema_conditional_required(cls, data: Any) -> Any:
        if not isinstance(data, dict):
            return data
        condition = {{ rule.condition|repr }}
        then_required_groups = {{ rule.then_groups|repr }}
        else_required_groups = {{ rule.else_groups|repr }}
        condition_matches = all(
            any(name in data and data[name] in expected for name in names)
            for names, expected in condition
        )
        required_groups = (
            then_required_groups if condition_matches else else_required_groups
        )
        for group in required_groups:
            if all(any(name in data for name in names) for names in group):
                continue
            raise ValueError('Conditional required properties are missing')
        return data
{%- set schema_validator_state.has_prior = true %}
{%- endfor %}
{%- endif %}
